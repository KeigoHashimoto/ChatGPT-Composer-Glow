{
  "manifest_version": 3,
  "name": "ChatGPT Composer Glow",
  "short_name": "Composer Glow",
  "description": "Adds subtle, privacy-friendly visual state cues to the ChatGPT composer and responses.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
